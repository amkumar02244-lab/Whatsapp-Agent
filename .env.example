# ============================================
# WhatsApp AI Support Agent — Environment Vars
# Copy this to .env and fill in your values
# ============================================

# --- Meta / WhatsApp Cloud API ---
# Get these from developers.facebook.com after creating your app
WHATSAPP_TOKEN=your_permanent_access_token_here
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id_here
WEBHOOK_VERIFY_TOKEN=pick_any_random_string_eg_mysecret123

# --- Anthropic Claude API ---
# Get from console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your-key-here

# --- App Config ---
PORT=3000
NODE_ENV=development
# Path to the database files (.csv folder)
DATABASE_DIR=C:/Users/amank/OneDrive/Desktop/Ecommerce/ecommerce-backend/data


# --- Demo Brand Config (for YES2026 demo) ---
# This is the "Riya's Boutique" demo brand
DEMO_BRAND_NAME=Riya's Boutique
DEMO_BRAND_CATEGORY=fashion

# ============================================
# HOW TO GET EACH VALUE:
#
# WHATSAPP_TOKEN:
#   1. Go to developers.facebook.com
#   2. Create App → Business → Add WhatsApp
#   3. Go to WhatsApp > API Setup
#   4. Generate permanent token via System User
#
# WHATSAPP_PHONE_NUMBER_ID:
#   Same page as above — listed under "From"
#
# WEBHOOK_VERIFY_TOKEN:
#   You make this up. Any random string.
#   Must match what you enter in Meta dashboard.
#
# ANTHROPIC_API_KEY:
#   console.anthropic.com → API Keys → Create Key
# ============================================
